# Backend Selection
LLM_BACKEND=ollama  # Options: ollama, vllm, mock

# Ollama Configuration (for local)
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=phi3:mini
OLLAMA_TIMEOUT=60

# vLLM Configuration (for production)
VLLM_API_URL=http://localhost:8000/v1/completions
VLLM_API_KEY=dummy
VLLM_TIMEOUT=60

# Database
DATABASE_PATH=./data/budget.db

# App Environment
APP_ENV=development